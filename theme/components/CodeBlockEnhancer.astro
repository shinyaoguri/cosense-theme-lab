---
// Adds a language label above and a copy-to-clipboard button inside every
// .page-content <pre> block. The associated styles live in global.css
// (.code-block-lang, .code-block-copy).
---
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const blocks = document.querySelectorAll<HTMLPreElement>(".page-content pre");
    blocks.forEach((pre) => {
      if (pre.classList.contains("is-enhanced")) return;
      pre.classList.add("is-enhanced");

      const code = pre.querySelector("code");
      let lang = pre.getAttribute("data-language") ?? "";
      if (!lang && code) {
        const m = code.className.match(/language-(\w+)/);
        if (m?.[1]) lang = m[1];
      }
      if (lang) {
        const label = document.createElement("span");
        label.className = "code-block-lang";
        label.textContent = lang;
        pre.parentNode?.insertBefore(label, pre);
      }

      const btn = document.createElement("button");
      btn.className = "code-block-copy";
      btn.textContent = "Copy";
      btn.setAttribute("type", "button");
      btn.addEventListener("click", async () => {
        const text = code?.textContent ?? pre.textContent ?? "";
        try {
          await navigator.clipboard.writeText(text);
          btn.textContent = "Copied";
          btn.classList.add("is-copied");
          setTimeout(() => {
            btn.textContent = "Copy";
            btn.classList.remove("is-copied");
          }, 1800);
        } catch {
          btn.textContent = "Failed";
          setTimeout(() => { btn.textContent = "Copy"; }, 1800);
        }
      });
      pre.appendChild(btn);
    });
  });
</script>
