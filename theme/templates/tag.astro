---
import { getCollection } from "astro:content";
import Layout from "../components/Layout.astro";
import { isPublicTag, path } from "@cosense-site-kit/theme-utils";

export async function getStaticPaths() {
  const pages = await getCollection("pages");
  const tagMap = new Map<string, typeof pages>();
  for (const entry of pages) {
    for (const t of entry.data.tags) {
      if (!isPublicTag(t)) continue;
      const list = tagMap.get(t) ?? [];
      list.push(entry);
      tagMap.set(t, list);
    }
  }
  return Array.from(tagMap.entries()).map(([t, entries]) => ({
    params: { tag: t },
    props: { entries },
  }));
}

const { tag } = Astro.params;
const { entries } = Astro.props as {
  entries: Awaited<ReturnType<typeof getCollection<"pages">>>;
};
const total = entries.length;
---
<Layout title={`#${tag}`} hideToc>
  <header class="page-header">
    <h1>#{tag}</h1>
    <p class="summary">{total} page{total === 1 ? "" : "s"}</p>
  </header>
  <ul class="tag-page-list">
    {entries.map((entry) => (
      <li>
        <a href={path(entry.data.slug)}>{entry.data.title}</a>
        {entry.data.summary && <p class="summary">{entry.data.summary}</p>}
      </li>
    ))}
  </ul>
</Layout>
