---
import { getCollection } from "astro:content";
import options from "virtual:cosense-theme-lab/options";
import Layout from "../components/Layout.astro";
import PageContent from "@cosense-site-kit/theme-utils/components/PageContent.astro";
import { loadStructure, path } from "@cosense-site-kit/theme-utils";
import { newsSummary, formatNewsDate } from "../lib/news";

const structure = await loadStructure();
const homeTarget = structure.home?.page ?? options.homePage;
const all = await getCollection("pages");
const homeEntry = homeTarget
  ? all.find((e) => e.data.title === homeTarget || e.data.slug === homeTarget)
  : undefined;

// Recent news (most recent N tagged with the news tag).
const newsTag = structure.posts?.tag ?? options.newsTag;
const news = all
  .filter((e) => e.data.tags.includes(newsTag))
  .map((e) => newsSummary(e))
  .sort((a, b) => (b.date?.getTime() ?? 0) - (a.date?.getTime() ?? 0))
  .slice(0, structure.posts?.limit ?? 5);

// Up to 4 featured research topics (preserves .site `featured` order).
const researchTag = options.researchTag;
const titleToEntry = new Map(all.map((e) => [e.data.title, e]));
const featured = structure.featured
  .map((title) => titleToEntry.get(title))
  .filter((e): e is NonNullable<typeof e> => Boolean(e))
  .slice(0, 4);
---
<Layout title="Home" wide>
  {homeEntry && (
    <section class="prose">
      <PageContent blocks={homeEntry.data.blocks} />
    </section>
  )}

  {featured.length > 0 && (
    <section style="margin-top: 3rem">
      <h2 style="font-size: 1.125rem; margin-bottom: 1rem">Featured research</h2>
      <ul class="research-grid">
        {featured.map((entry) => (
          <li>
            <a class="research-card" href={path(entry.data.slug)}>
              <h3>{entry.data.title}</h3>
              {entry.data.summary && <p>{entry.data.summary}</p>}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {news.length > 0 && (
    <section style="margin-top: 3rem">
      <h2 style="font-size: 1.125rem; margin-bottom: 1rem">Recent news</h2>
      <ul class="news-list">
        {news.map((n) => (
          <li>
            <time class="news-date" datetime={n.date?.toISOString()}>
              {formatNewsDate(n.date)}
            </time>
            <a class="news-link" href={path(n.slug)}>{n.title}</a>
          </li>
        ))}
      </ul>
    </section>
  )}
</Layout>
