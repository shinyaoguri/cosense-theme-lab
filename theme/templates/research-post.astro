---
import type { CollectionEntry } from "astro:content";
import Layout from "../components/Layout.astro";
import PageContent from "@cosense-site-kit/theme-utils/components/PageContent.astro";
import Backlinks from "@cosense-site-kit/theme-utils/components/Backlinks.astro";
import { isPublicTag, path } from "@cosense-site-kit/theme-utils";

interface Props { entry: CollectionEntry<"pages"> }
const { entry } = Astro.props;
const page = entry.data;
const tags = page.tags.filter(isPublicTag);
---
<Layout title={page.title} description={page.summary}>
  <article class="prose">
    <p style="font-size: 0.8125rem; color: var(--color-text-muted); margin: 0 0 0.5rem">
      <a href={path("research")}>← Research</a>
    </p>
    <h1>{page.title}</h1>
    {tags.length > 0 && (
      <p>
        {tags.map((t) => (
          <a class="tag" href={path(`tags/${t}`)}>#{t}</a>
        ))}
      </p>
    )}
    <PageContent blocks={page.blocks} />
    <Backlinks backlinks={page.backlinks} />
    <p class="source-link">
      <a href={page.sourceUrl} target="_blank" rel="noopener noreferrer">
        Source on Cosense ↗
      </a>
    </p>
  </article>
</Layout>
