---
import type { CollectionEntry } from "astro:content";
import Layout from "../components/Layout.astro";
import PageContent from "@cosense-site-kit/theme-utils/components/PageContent.astro";
import { extractPublications, sortPublicationsDesc } from "../lib/publications";

interface Props { entry: CollectionEntry<"pages"> }
const { entry } = Astro.props;
const page = entry.data;
const data = extractPublications(page.blocks);
const pubs = data ? sortPublicationsDesc(data.publications) : [];

// Bucket by year (number or string). Stable iteration via insertion order
// from sortPublicationsDesc (newest year first).
const buckets = new Map<string, typeof pubs>();
for (const p of pubs) {
  const key = String(p.year);
  const list = buckets.get(key) ?? [];
  list.push(p);
  buckets.set(key, list);
}
---
<Layout title={page.title} description={page.summary} image={page.image} hideToc>
  <article data-pagefind-body>
    <header class="page-header">
      <h1>{page.title}</h1>
    </header>

    {data ? (
      <>
        <div class="pub-filters">
          <button type="button" data-filter="all" class="pub-filter is-active">All</button>
          <button type="button" data-filter="peer-reviewed" class="pub-filter">Peer-reviewed</button>
          <button type="button" data-filter="full-paper" class="pub-filter">Full-paper</button>
        </div>

        {Array.from(buckets.entries()).map(([year, items]) => (
          <section class="pub-section">
            <h2>{year}</h2>
            <ul class="pub-list">
              {items.map((p) => (
                <li
                  class="pub-item"
                  data-peer-reviewed={p.peerReviewed ? "true" : "false"}
                  data-full-paper={p.fullPaper ? "true" : "false"}
                >
                  {p.authors}, {p.url ? (
                    <a href={p.url} target="_blank" rel="noopener noreferrer">"{p.title}"</a>
                  ) : (
                    <>"{p.title}"</>
                  )}, {p.source}.
                  {p.peerReviewed && <span class="pub-badge">Peer-reviewed</span>}
                  {p.fullPaper && <span class="pub-badge">Full-paper</span>}
                </li>
              ))}
            </ul>
          </section>
        ))}
      </>
    ) : (
      <>
        <p class="summary">
          論文一覧は <code>code:publications.yaml</code> ブロックで定義してください。
        </p>
        <PageContent blocks={page.blocks} hideFilenames={["publications.yaml"]} />
      </>
    )}
  </article>
</Layout>

<style>
  .pub-filters {
    display: flex;
    gap: 0.375rem;
    margin-bottom: 1.5rem;
  }
  .pub-filter {
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-family: inherit;
    background: var(--color-bg-soft);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .pub-filter:hover { color: var(--color-text); }
  .pub-filter.is-active {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".pub-filter");
  const items = document.querySelectorAll<HTMLLIElement>(".pub-item");
  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter;
      buttons.forEach((b) => b.classList.toggle("is-active", b === btn));
      items.forEach((item) => {
        if (filter === "all") item.style.display = "";
        else if (filter === "peer-reviewed")
          item.style.display = item.dataset.peerReviewed === "true" ? "" : "none";
        else if (filter === "full-paper")
          item.style.display = item.dataset.fullPaper === "true" ? "" : "none";
      });
    });
  });
</script>
